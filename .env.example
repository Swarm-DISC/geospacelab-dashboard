# Copy to .env (gitignored) and adjust. All values are optional.

# Runtime mode: "local" (default) uses your existing ~/.geospacelab/config.toml as-is.
# "docker" seeds an ephemeral config pointing data at a temp dir and disables live
# previews for credential-gated sources (code is still generated).
DASHBOARD_MODE=local

# Docker mode only: where to download data. Empty -> a temp directory is created.
GEOSPACELAB_DATA_ROOT=

# Preview guardrails.
GSL_PREVIEW_TIMEOUT=180
GSL_PREVIEW_DPI=96

# Attempt live previews for geomap sources (AMPERE/SuperDARN). Off by default; needs the
# [geo] extra (cartopy) and a manually downloaded file.
GSL_ENABLE_GEOMAP_PREVIEW=0

# --- Credentials are read by geospacelab itself, not this app. ---
# Local mode: configure them once in ~/.geospacelab/config.toml, e.g.
#   [datahub.esa_eo]   username = "you@example.com"     (password via keyring)
#   [datahub.madrigal] user_fullname/user_email/user_affiliation = ...
# Docker mode: inject equivalents in deploy/entrypoint.sh.
